# Production Environment Variables - Horizon Hotels Client
# Copy this to .env.production and fill in your actual values

# API Configuration
VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_WS_URL=wss://api.yourdomain.com

# OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# Map Configuration
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Analytics Configuration
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Application Configuration
VITE_APP_NAME=Horizon Hotels
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Premium Hotel Booking Platform

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_AI_FEATURES=true

# PWA Configuration
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Environment
VITE_NODE_ENV=production
