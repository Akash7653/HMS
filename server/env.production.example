# Production Environment Variables - Horizon Hotels
# Copy this to .env.production and fill in your actual values

# Database Configuration
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/hotels_prod?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE_DAYS=30

# Redis Configuration
REDIS_URL=redis://your-redis-cloud-url:6379
REDIS_PASSWORD=your_redis_password

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/oauth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/auth/oauth/facebook/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Cloudinary Configuration (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your_email@example.com

# Analytics & Tracking
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Application Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Security Configuration
CORS_ORIGIN=https://yourdomain.com
SESSION_SECRET=your_session_secret_key
BCRYPT_ROUNDS=12

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Monitoring & Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Database Connection Pool
DB_POOL_MIN=5
DB_POOL_MAX=20

# External API Keys
OPENWEATHER_API_KEY=your_openweather_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# SMS Configuration (Optional)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Business Configuration
DEFAULT_COMMISSION_RATE=0.15
MIN_PAYOUT_AMOUNT=1000
COMMISSION_HOLD_DAYS=7

# Loyalty Program Configuration
LOYALTY_POINTS_PER_RUPEE=0.1
LOYALTY_POINTS_EXPIRY_DAYS=365

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_ANALYTICS=true
ENABLE_PWA_NOTIFICATIONS=true
ENABLE_DYNAMIC_PRICING=true
ENABLE_MULTI_VENDOR=true
